// NestJS Ticket Booking Database Schema (DBML)
// Docs: https://dbml.org/docs/
// Generated: 2026-07-04
// Author: Antigravity

Project TicketBooking {
  database_type: 'PostgreSQL'
  Note: 'Production-ready database schema for a High-Concurrency Cinema Ticket Booking System in NestJS'
}

// ==========================================
// ENUM DECLARATIONS (DOMAIN TYPES)
// ==========================================

enum user_role {
  user
  admin
  staff
}

enum user_status {
  active
  inactive
  suspended
  pending_verification
}

enum show_seat_status {
  available
  reserved
  booked
}

enum booking_status {
  pending_payment
  confirmed
  cancelled
  expired
}

enum payment_status {
  pending
  completed
  failed
  refunded
}

enum outbox_event_status {
  pending
  processed
  failed
}

enum payment_method {
  MOMO
  VNPAY
  Credit_Card
  ShopeePay
}

enum discount_type {
  percentage
  flat
}

enum movie_rating {
  G
  PG
  PG_13
  R
  NC_17
}

// ==========================================
// 1. USER & AUTHENTICATION MANAGEMENT
// ==========================================

Table users {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  email varchar(255) [not null, unique]
  full_name varchar(255) [not null]
  phone_number varchar(20)
  avatar_url text
  password_hash text [note: 'Nullable for OAuth users']
  google_id varchar(255) [unique, note: 'Nullable, unique OAuth ID']
  facebook_id varchar(255) [unique, note: 'Nullable, unique OAuth ID']
  role user_role [not null, default: 'user']
  status user_status [not null, default: 'pending_verification']
  verification_token varchar(255) [unique, note: 'Token or OTP code for email verification (plain text or hashed)']
  verification_expires_at timestamptz [note: 'Expiration time of the verification token/OTP']

  Note: 'Unified User table containing local auth & social OAuth fields'

  Indexes {
    email [unique, name: "users_email_uidx"]
    google_id [unique, name: "users_google_id_uidx"]
    facebook_id [unique, name: "users_facebook_id_uidx"]
    verification_token [unique, name: "users_verification_token_uidx"]
    verification_expires_at [name: "users_verification_expires_at_idx", note: "Partial index: WHERE status = 'pending_verification'"]
    phone_number [name: "users_phone_number_idx"]
  }
}

Table refresh_tokens {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  user_id uuid [not null, note: 'Links token to a specific user']
  token_hash varchar(255) [not null, unique, note: 'Hashed refresh token (SHA-256) for security']
  device_name varchar(255) [note: 'E.g. Chrome on Windows, iPhone App']
  ip_address varchar(45) [note: 'IPv4 or IPv6 address for security logging']
  expires_at timestamp [not null, note: 'Expiration time of the token']
  is_revoked boolean [not null, default: false, note: 'For blacklisting/rotation detection']

  Note: 'Separate table for managing multiple concurrent user sessions and token rotation'

  Indexes {
    token_hash [unique, name: "refresh_tokens_token_hash_uidx"]
    user_id [name: "refresh_tokens_user_id_idx"]
  }
}

// ==========================================
// 2. MOVIE CATALOG MANAGEMENT
// ==========================================

Table movies {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  tmdb_id varchar(50) [unique, note: 'External ID from TheMovieDB API for dynamic metadata syncing']
  imdb_id varchar(50) [unique, note: 'External ID from IMDb API for reviews & ratings']
  duration_minutes integer [not null]
  release_date date
  poster_url text
  trailer_url text
  rating movie_rating [note: 'Age-based rating classification, e.g. G, PG, PG-13, R, NC-17']

  Note: 'Catalog of films/movies available for screening (Technical data only)'
}

Table genres {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  name varchar(100) [not null, unique]

  Note: 'Movie genre classifications (e.g. Action, Comedy, Horror)'
}

Table movie_genres {
  movie_id uuid [not null]
  genre_id uuid [not null]

  Note: 'Junction table for Movie-Genre many-to-many relationship'

  Indexes {
    (movie_id, genre_id) [pk]
    genre_id [name: "movie_genres_genre_id_idx"]
  }
}

Table movie_translations {
  movie_id uuid [not null]
  language_code varchar(10) [not null, note: 'Language code, e.g. vi, en']
  title varchar(255) [not null]
  description text

  Note: 'Localized metadata for movies (i18n)'

  Indexes {
    (movie_id, language_code) [pk]
  }
}

// ==========================================
// 3. CINEMA VENUE & HALL LAYOUT
// ==========================================

Table cinemas {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  name varchar(255) [not null, note: 'E.g. CGV Vincom Center, BHD Star']
  address varchar(255)

  Note: 'Cinema branches or physical theater locations'
}

Table halls {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  cinema_id uuid [not null, note: 'Links hall to a specific cinema branch']
  name varchar(255) [not null, note: 'E.g. Phòng chiếu A, Phòng chiếu B, Hall 1, Room 2']
  total_seats integer [not null, default: 0]

  Note: 'Individual screening halls inside a cinema branch (Phòng chiếu A, B, C)'

  Indexes {
    cinema_id [name: "halls_cinema_id_idx"]
  }
}

Table seat_types {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  name varchar(50) [not null, unique, note: 'E.g. Standard, VIP, Couple, Sweetbox']
  price_multiplier decimal(4,2) [not null, default: 1.00, note: 'Factor to calculate seat price based on show base price']

  Note: 'Seat classification tiers for pricing and experience'
}

Table seats {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  hall_id uuid [not null, note: 'Links physical seat to a screening hall']
  seat_type_id uuid [not null, note: 'Defines if seat is Standard, VIP, etc.']
  row varchar(10) [not null, note: 'Row letter, e.g. A, B, C']
  number integer [not null, note: 'Seat number in the row']
  seat_number varchar(20) [not null, note: 'E.g. A1, A2, B10']

  Note: 'Physical seats permanently installed in screening halls'

  Indexes {
    (hall_id, seat_number) [unique, name: "seats_hall_id_seat_number_uidx"]
    seat_type_id [name: "seats_seat_type_id_idx"]
  }
}

// ==========================================
// 4. SHOWTIMES & CONCURRENT SEAT STATUS
// ==========================================

Table shows {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  movie_id uuid [not null, note: 'Movie being screened']
  hall_id uuid [not null, note: 'Hall where screening happens']
  start_time timestamp [not null, note: 'Screening start time']
  end_time timestamp [not null, note: 'Screening end time']
  base_price integer [not null, note: 'Base ticket price in minor units (e.g. VND / cents)']

  Note: 'Screening instances linking a movie to a specific hall and schedule'

  Indexes {
    (movie_id, start_time) [name: "shows_movie_id_start_time_idx"]
    (hall_id, start_time) [name: "shows_hall_id_start_time_idx"]
  }
}

Table show_seats {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  show_id uuid [not null, note: 'Links status to specific showtime']
  seat_id uuid [not null, note: 'Links status to physical seat']
  status show_seat_status [not null, default: 'available']
  locked_until timestamp [note: 'Soft lock timestamp expiration for checkout timer (e.g. 10m)']

  Note: 'Seat occupancy status for specific shows. Locked under high concurrency via SELECT ... FOR UPDATE'

  Indexes {
    (show_id, seat_id) [unique, name: "show_seats_show_id_seat_id_uidx"]
    (status, locked_until) [name: "show_seats_status_locked_until_idx"]
  }
}

// ==========================================
// 5. BOOKINGS, TICKETS & PROMOTIONS
// ==========================================

Table vouchers {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  code varchar(50) [not null, unique, note: 'Discount coupon code']
  discount_type discount_type [not null]
  discount_value integer [not null, note: 'Percentage value (e.g. 10) or Flat value (e.g. 50000)']
  min_booking_amount integer [not null, default: 0]
  max_discount_amount integer [note: 'Cap for percentage discount']
  start_date timestamp [not null]
  end_date timestamp [not null]
  usage_limit integer [note: 'Max total uses allowed for the code']
  usage_count integer [not null, default: 0]

  Note: 'Promotional discount coupons'
}

Table bookings {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  user_id uuid [not null]
  show_id uuid [not null]
  voucher_id uuid [note: 'Discount coupon applied']
  original_price integer [not null, note: 'Sum of seats & combos prices before discount']
  discount_price integer [not null, default: 0, note: 'Discount value deducted']
  total_price integer [not null, note: 'Final price payable by user']
  status booking_status [not null, default: 'pending_payment']
  expires_at timestamp [not null, note: 'Auto-released by BullMQ worker after 10 minutes if unpaid']

  Note: 'Customer orders and reservations'

  Indexes {
    (user_id, created_at) [name: "bookings_user_id_created_at_idx"]
    show_id [name: "bookings_show_id_idx"]
    voucher_id [name: "bookings_voucher_id_idx"]
    (status, expires_at) [name: "bookings_status_expires_at_idx"]
  }
}

Table tickets {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  booking_id uuid [not null, note: 'Order reference']
  show_seat_id uuid [not null, note: 'Specific occupied seat instance']
  ticket_code varchar(100) [not null, unique, note: 'QR/SMS validation code']
  final_price integer [not null, note: 'Price paid for this seat ticket']

  Note: 'Individual tickets issued per booked seat'

  Indexes {
    ticket_code [unique, name: "tickets_ticket_code_uidx"]
    (booking_id, show_seat_id) [unique, name: "tickets_booking_id_show_seat_id_uidx"]
    show_seat_id [name: "tickets_show_seat_id_idx"]
  }
}

// ==========================================
// 6. CONCESSION / COMBOS (SNACKS & DRINKS)
// ==========================================

Table combos {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  name varchar(255) [not null, note: 'E.g. Combo Bắp Nước Solo']
  description text
  price integer [not null, note: 'Combo price in minor units']
  is_active boolean [not null, default: true]

  Note: 'Snacks, popcorn, and drinks concessions catalog'
}

Table booking_combos {
  booking_id uuid [not null]
  combo_id uuid [not null]
  quantity integer [not null, default: 1]

  Note: 'Concessions ordered within a booking'

  Indexes {
    (booking_id, combo_id) [pk]
  }
}

// ==========================================
// 7. PAYMENTS & AUDITING / OUTBOX EVENTS
// ==========================================

Table payments {
  id uuid [pk, note: 'Time-sortable UUIDv7 primary key']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  booking_id uuid [not null, note: 'Booking paid for']
  payment_method payment_method [not null]
  transaction_id varchar(255) [unique, note: 'Third-party gateway reference ID']
  amount integer [not null]
  status payment_status [not null]

  Note: 'Payment transactions linked to bookings'

  Indexes {
    transaction_id [unique, name: "payments_transaction_id_uidx"]
    booking_id [name: "payments_booking_id_idx"]
  }
}

Table outbox_events {
  id uuid [pk, note: 'UUIDv7 primary key, also used as BullMQ idempotent jobId']
  created_at timestamp [not null, default: `now()`]
  event_type varchar(255) [not null, note: 'E.g. booking.created, payment.completed']
  payload jsonb [not null, note: 'JSON serialization of event data']
  status outbox_event_status [not null, default: 'pending']
  processed_at timestamp [note: 'Timestamp when event was relayed to BullMQ']

  Note: 'Transactional Outbox pattern table for atomic event emission'

  Indexes {
    (status, created_at) [name: "outbox_events_status_created_at_idx"]
  }
}

// ==========================================
// FOREIGN KEY RELATIONSHIPS
// ==========================================

Ref: refresh_tokens.user_id > users.id [delete: cascade]

Ref: movie_translations.movie_id > movies.id [delete: cascade]

Ref: movie_genres.movie_id > movies.id [delete: cascade]
Ref: movie_genres.genre_id > genres.id [delete: cascade]

Ref: halls.cinema_id > cinemas.id [delete: cascade]
Ref: seats.hall_id > halls.id [delete: cascade]
Ref: seats.seat_type_id > seat_types.id [delete: restrict]

Ref: shows.movie_id > movies.id [delete: restrict]
Ref: shows.hall_id > halls.id [delete: restrict]

Ref: show_seats.show_id > shows.id [delete: cascade]
Ref: show_seats.seat_id > seats.id [delete: restrict]

Ref: bookings.user_id > users.id [delete: restrict]
Ref: bookings.show_id > shows.id [delete: restrict]
Ref: bookings.voucher_id > vouchers.id [delete: set null]

Ref: booking_combos.booking_id > bookings.id [delete: cascade]
Ref: booking_combos.combo_id > combos.id [delete: restrict]

Ref: tickets.booking_id > bookings.id [delete: cascade]
Ref: tickets.show_seat_id > show_seats.id [delete: restrict]

Ref: payments.booking_id > bookings.id [delete: restrict]
