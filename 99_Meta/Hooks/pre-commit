#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status
set -e

# Get list of staged files (Added, Copied, Modified)
# Using mapfile to handle spaces in filenames cleanly
mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    exit 0
fi

# Filter markdown and js/mjs files
MD_FILES=()
JS_FILES=()

for FILE in "${STAGED_FILES[@]}"; do
    if [[ "$FILE" =~ \.md$ ]]; then
        MD_FILES+=("$FILE")
    elif [[ "$FILE" =~ \.(js|mjs)$ ]]; then
        JS_FILES+=("$FILE")
    fi
done

# Run Biome check (formatter & linter) for JS/MJS files
if [ ${#JS_FILES[@]} -gt 0 ]; then
    echo "Formatting and Linting JavaScript/TypeScript files with Biome..."
    biome check --write "${JS_FILES[@]}"
    git add "${JS_FILES[@]}"
fi

# Run Prettier formatter for Markdown files
# if [ ${#MD_FILES[@]} -gt 0 ]; then
# fi

echo "Formatting Markdown files with Prettier..."
bunx prettier --write .
git add .

# Run Note Validator
echo "Running note validation..."
bun 99_Meta/Scripts/validate_notes.mjs
